{
  "name": "@vutler/custom",
  "version": "1.0.0",
  "description": "Vutler AI Agent Management Platform",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --testPathPattern='tests/' --forceExit 2>/dev/null || bash tests/run-all.sh",
    "test:unit": "jest tests/llm-router.test.js --forceExit",
    "test:llm": "jest tests/llm-router.test.js tests/llm-api.test.js --forceExit",
    "test:drive": "jest tests/drive-api.test.js --forceExit",
    "test:agent": "node tests/agent-identity.test.js",
    "test:email-send": "node tests/email-send.test.js",
    "test:email-receive": "node tests/email-receive.test.js",
    "test:chat": "node tests/chat.test.js",
    "test:watch": "nodemon --exec npm test",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true,
    "testTimeout": 30000
  },
  "keywords": [
    "vutler",
    "office",
    "ai-agents",
    "collaboration"
  ],
  "author": "Vutler Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "ajv": "^8.18.0",
    "axios": "^1.6.0",
    "chokidar": "^4.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.6.5",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.0",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "eslint": "^8.50.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3"
  },
  "overrides": {
    "semver": ">=7.6.0"
  }
}
