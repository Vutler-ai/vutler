# ============================================
# Vutler Platform - Environment Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development

# ============================================
# Database (Vaultbrix PostgreSQL via SSH tunnel)
# ============================================
# SSH tunnel: ssh -i ~/.ssh/vaultbrix_ed25519 -L 15432:localhost:5433 ubuntu@REDACTED_DB_HOST
# Then set VAULTBRIX_PASSWORD env var when starting the server
DATABASE_URL=postgresql://tenant_vutler:${VAULTBRIX_PASSWORD}@localhost:15432/postgres?options=-csearch_path%3Dtenant_vutler

# Vaultbrix connection details
VAULTBRIX_HOST=localhost
VAULTBRIX_PORT=15432
VAULTBRIX_DB=postgres
VAULTBRIX_USER=tenant_vutler
# VAULTBRIX_PASSWORD — set via env var, never commit

# ============================================
# Security
# ============================================
# IMPORTANT: Change this to a strong random string in production!
JWT_SECRET=REDACTED_JWT_FALLBACK

# Encryption key for sensitive data
ENCRYPTION_KEY=your-encryption-key-32chars-long!!

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================
# LLM Providers
# ============================================
# OpenRouter (Primary)
OPENROUTER_API_KEY=sk-or-

# Anthropic (Direct)
ANTHROPIC_API_KEY=sk-ant-

# MiniMax
MINIMAX_API_KEY=

# ============================================
# Snipara Integration
# ============================================
SNIPARA_API_URL=https://api.snipara.com/mcp/vutler
SNIPARA_API_KEY=

# ============================================
# Redis (optional - for caching/pub-sub)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Email (IMAP - optional)
# ============================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
IMAP_POLL_INTERVAL=5

# Webhook for email processing
VUTLER_EMAIL_WEBHOOK_URL=

# ============================================
# File Storage
# ============================================
DRIVE_STORAGE_PATH=/data/drive

# ============================================
# Billing (optional)
# ============================================
BILLING_UPGRADE_URL=/billing/upgrade

# ============================================
# GitHub Integration (optional)
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_REDIRECT_URI=https://vutler.starboxgroup.com/auth/github/callback

# ============================================
# Vutler Nexus (Local Agent)
# ============================================
VUTLER_API_URL=https://app.vutler.ai
VUTLER_API_KEY=
