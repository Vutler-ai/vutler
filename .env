# ============================================
# Vutler Platform - Environment Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development

# ============================================
# Database (Vaultbrix PostgreSQL)
# ============================================
DATABASE_URL=postgresql://vutler:vutler@localhost:5432/vutler

# Alternative Vaultbrix connection (if needed)
VAULTBRIX_HOST=localhost
VAULTBRIX_PORT=5432
VAULTBRIX_DB=vutler
VAULTBRIX_USER=vutler
VAULTBRIX_PASSWORD=vutler

# ============================================
# Security
# ============================================
# IMPORTANT: Change this to a strong random string in production!
JWT_SECRET=REDACTED_JWT_FALLBACK

# Encryption key for sensitive data
ENCRYPTION_KEY=your-encryption-key-32chars-long!!

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================
# Rocket.Chat (if using RC integration)
# ============================================
RC_WS_URL=ws://localhost:3000/websocket
RC_API_URL=http://localhost:3000
RC_ADMIN_TOKEN=
RC_ADMIN_USER_ID=
RC_ADMIN_USERNAME=admin
RC_ADMIN_PASSWORD=

# ============================================
# LLM Providers
# ============================================
# OpenRouter (Primary)
OPENROUTER_API_KEY=sk-or-

# Anthropic (Direct)
ANTHROPIC_API_KEY=sk-ant-

# MiniMax
MINIMAX_API_KEY=

# ============================================
# Snipara Integration
# ============================================
SNIPARA_API_URL=https://api.snipara.com/mcp/vutler
SNIPARA_API_KEY=

# ============================================
# Redis (optional - for caching/pub-sub)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Email (IMAP - optional)
# ============================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
IMAP_POLL_INTERVAL=5

# Webhook for email processing
VUTLER_EMAIL_WEBHOOK_URL=

# ============================================
# File Storage
# ============================================
DRIVE_STORAGE_PATH=/data/drive

# ============================================
# Billing (optional)
# ============================================
BILLING_UPGRADE_URL=/billing/upgrade

# ============================================
# GitHub Integration (optional)
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_REDIRECT_URI=https://vutler.starboxgroup.com/auth/github/callback

# ============================================
# Vutler Nexus (Local Agent)
# ============================================
VUTLER_API_URL=https://app.vutler.ai
VUTLER_API_KEY=
