NODE_ENV=production
PORT=3001
APP_URL=https://app.vutler.ai

# ── Database (Vaultbrix) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres
VAULTBRIX_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Snipara (Agent Memory) ────────────────────────────────────────────────────
SNIPARA_API_URL=https://api.snipara.com/mcp/YOUR_PROJECT_SLUG
SNIPARA_API_KEY=
SNIPARA_SWARM_ID=

# ── S3 / Drive (Exoscale Object Storage) ─────────────────────────────────────
S3_ENDPOINT=https://sos-ch-gva-2.exo.io
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=ch-gva-2
S3_FORCE_PATH_STYLE=false
S3_BUCKET_PREFIX=
S3_BUCKET=

# ── Postal (Email) ────────────────────────────────────────────────────────────
POSTAL_API_URL=http://localhost:8082
POSTAL_API_KEY=
POSTAL_HOST=mail.vutler.ai
EMAIL_DOMAIN=yourdomain.com

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Trial Tokens (Onboarding) ───────────────────────────────────────────────
# Shared OpenAI key used to provision trial tokens for new workspaces.
# Model restricted to gpt-4o-mini, 50k tokens, 7 days expiry, 5 req/min.
VUTLER_TRIAL_OPENAI_KEY=
VUTLER_TRIAL_TOKENS_TOTAL=50000
VUTLER_TRIAL_EXPIRY_DAYS=7

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=
STRIPE_PRICE_OFFICE_STARTER_MONTHLY=
STRIPE_PRICE_OFFICE_STARTER_YEARLY=
STRIPE_PRICE_OFFICE_TEAM_MONTHLY=
STRIPE_PRICE_OFFICE_TEAM_YEARLY=
STRIPE_PRICE_AGENTS_STARTER_MONTHLY=
STRIPE_PRICE_AGENTS_STARTER_YEARLY=
STRIPE_PRICE_AGENTS_PRO_MONTHLY=
STRIPE_PRICE_AGENTS_PRO_YEARLY=
STRIPE_PRICE_FULL_MONTHLY=
STRIPE_PRICE_FULL_YEARLY=

# ── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://app.vutler.ai/api/v1/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.vutler.ai/api/v1/auth/google/callback

# ── ChatGPT / Codex OAuth (PKCE public client — no secret needed) ────────────
CHATGPT_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# ── Encryption (REQUIRED — security audit 2026-03-28) ────────────────────────
# Min 32 chars random string. Used by CryptoService for AES-256-GCM at rest.
ENCRYPTION_KEY=

# ── Social Media Posting (Post for Me) ────────────────────────────────────────
POSTFORME_API_KEY=
POSTFORME_API_URL=https://app.postforme.dev/api/v1
POSTFORME_REDIRECT_URL=https://app.vutler.ai/settings/integrations/social-media/callback

# Legacy (direct posting — deprecated, use Post for Me)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DB_HOST=
BACKUP_DB_USER=
BACKUP_DB_PASSWORD=

# ── Webhooks ─────────────────────────────────────────────────────────────────
SNIPARA_WEBHOOK_SECRET=
