# =========================================================
# Vutler — Environment Variables (public-safe template)
# =========================================================

# ---------- Runtime ----------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated origins (e.g. https://app.vutler.ai,https://vutler.ai)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# ---------- Security ----------
JWT_SECRET=change-me-super-long-random-secret
VUTLER_ENCRYPTION_KEY=change-me-32+chars
LLM_ENCRYPTION_KEY=change-me-32+chars

# Optional admin bootstrap
ADMIN_EMAIL=admin@vutler.ai
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
VUTLER_ADMIN_API_KEY=change-me

# ---------- PostgreSQL ----------
# Preferred single URL
DATABASE_URL=postgresql://user:pass@localhost:5432/vutler

# Optional explicit PG config (if DATABASE_URL not used)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=vutler
PG_USER=postgres
PG_PASSWORD=postgres

# ---------- Legacy placeholders removed ----------

# ---------- LLM Providers ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MANAGED_LLM_PROVIDER=openai
MANAGED_LLM_KEY=

# Optional search provider
BRAVE_API_KEY=
BRAVE_SEARCH_API_KEY=

# ---------- Mail (SMTP/IMAP) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@vutler.ai

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_PASSWORD=
IMAP_TLS=true
IMAP_POLL_INTERVAL=60000

# ---------- Drive ----------
# Local storage path for drive API/files
DRIVE_STORAGE_PATH=./uploads
DRIVE_MAX_FILE_SIZE=52428800

# ---------- Internal/API links ----------
API_URL=http://localhost:3001
API_BASE=http://localhost:3001
VUTLER_API_URL=http://localhost:3001
VUTLER_WS_URL=ws://localhost:3001
VUTLER_EMAIL_WEBHOOK_URL=

# ---------- Optional integrations ----------
WHATSAPP_VERIFY_TOKEN=

# Snipara (optional)
SNIPARA_API_URL=
SNIPARA_API_KEY=
SNIPARA_WORKSPACE_ID=
SNIPARA_SWARM_ID=

# ---------- Feature / rate control ----------
VUTLER_AGENT_RATE_LIMIT=100
AGENT_WORKSPACE=default

# ---------- Tests ----------
TEST_API_URL=http://localhost:3001
E2E_TIMEOUT_MS=60000

# ---------- Deprecated / legacy ----------
# KDRIVE_ID is legacy (VDrive naming preferred)
KDRIVE_ID=
