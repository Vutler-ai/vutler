# LLM Provider (at least one required)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/vutler

# Snipara
SNIPARA_API_KEY=rlm_your_key_here
SNIPARA_PROJECT_KEY=rlm_your_key_here
SNIPARA_INTEGRATION_KEY=int_your_integrator_key_here
SNIPARA_WEBHOOK_URL=https://app.vutler.ai/api/v1/webhooks/snipara
SNIPARA_WEBHOOK_SECRET=whsec_your_webhook_secret_here
SNIPARA_PROJECT_SLUG=test-workspace-api-vutler
SNIPARA_PROJECT_ID=cmmfdy2up0002o1colc66rxs2
SNIPARA_PROJECT_MCP_URL=https://api.snipara.com/mcp/test-workspace-api-vutler
SNIPARA_SWARM_ID=cmmdu24k500g01ihbw32d44x2

# Server
PORT=3001
JWT_SECRET=change-me-to-random-string
ENCRYPTION_KEY=change-me-to-64-hex-chars
NODE_ENV=development

# Postal / workspace email
POSTAL_API_URL=http://127.0.0.1:8082
POSTAL_HOST=mail.vutler.ai
POSTAL_API_KEY=postal_your_server_api_key_here
EMAIL_DOMAIN=vutler.ai
VUTLER_FALLBACK_DOMAIN_SUFFIX=vutler.ai
VUTLER_MAIL_SERVER=mail.vutler.ai
# Postal inbound webhooks post to https://app.vutler.ai/api/v1/email/incoming
# Use the public key body from `postal default-dkim-record` (the value after `p=`).
POSTAL_INBOUND_WEBHOOK_KEY=your_postal_public_key_body_here
# Keep enabled in production. The API now fails closed if required and missing.
POSTAL_REQUIRE_WEBHOOK_SIGNATURE=true
# Optional defense-in-depth: require a shared secret in `X-Webhook-Secret`,
# `X-Vutler-Webhook-Secret`, or `?secret=...` in addition to Postal's signature.
POSTAL_INBOUND_WEBHOOK_SECRET=
POSTAL_REQUIRE_WEBHOOK_SECRET=false

# Sandbox
# Development defaults to local process execution.
# Production should use SANDBOX_RUNTIME=docker and expose /var/run/docker.sock to the API container.
# SANDBOX_RUNTIME=docker
# SANDBOX_DOCKER_BINARY=docker
# SANDBOX_DOCKER_NODE_IMAGE=node:22-alpine
# SANDBOX_DOCKER_PYTHON_IMAGE=python:3.12-alpine
# SANDBOX_DOCKER_MEMORY=128m
# SANDBOX_DOCKER_CPUS=0.50
# SANDBOX_DOCKER_PIDS_LIMIT=64
# SANDBOX_DOCKER_NETWORK=none
# SANDBOX_WORKER_POLL_MS=1000
# SANDBOX_WORKER_BATCH_SIZE=2

# Stripe
# For local development, you can keep test values in `.env`
# and put live or account-specific overrides in `.env.local`.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_ACCOUNT_ID=acct_your_connect_account_here
STRIPE_PRICE_OFFICE_STARTER_MONTHLY=price_your_office_starter_monthly
STRIPE_PRICE_OFFICE_STARTER_YEARLY=price_your_office_starter_yearly
STRIPE_PRICE_OFFICE_TEAM_MONTHLY=price_your_office_team_monthly
STRIPE_PRICE_OFFICE_TEAM_YEARLY=price_your_office_team_yearly
STRIPE_PRICE_AGENTS_STARTER_MONTHLY=price_your_agents_starter_monthly
STRIPE_PRICE_AGENTS_STARTER_YEARLY=price_your_agents_starter_yearly
STRIPE_PRICE_AGENTS_PRO_MONTHLY=price_your_agents_pro_monthly
STRIPE_PRICE_AGENTS_PRO_YEARLY=price_your_agents_pro_yearly
STRIPE_PRICE_FULL_MONTHLY=price_your_full_monthly
STRIPE_PRICE_FULL_YEARLY=price_your_full_yearly
STRIPE_PRICE_NEXUS_ENTERPRISE_MONTHLY=price_your_monthly_nexus_enterprise
STRIPE_PRICE_NEXUS_ENTERPRISE_YEARLY=price_your_yearly_nexus_enterprise
STRIPE_PRICE_ADDON_NEXUS_ENTERPRISE_SEATS_5=price_your_nexus_enterprise_seats_5
STRIPE_PRICE_ADDON_NEXUS_ENTERPRISE_NODE=price_your_nexus_enterprise_node
STRIPE_PRICE_ADDON_SOCIAL_POSTS_100=price_your_social_posts_100
STRIPE_PRICE_ADDON_SOCIAL_POSTS_500=price_your_social_posts_500
STRIPE_PRICE_ADDON_SOCIAL_POSTS_2000=price_your_social_posts_2000
