router.post('/keys', async (req, res) => {
  try {
    await ensureApiKeysTable();
    const created = await createApiKey({
      workspaceId: req.workspaceId || DEFAULT_WORKSPACE,
      userId: req.userId || req.user?.id || null,
      name: req.body?.name || 'Nexus key',
    });

    res.json({
