/**
 * @vutler/nexus — Agent Runtime Engine
 * Handles LLM interactions via Claude Code CLI, tool execution, and conversation management
 */
const { spawn } = require('child_process');
const { EventEmitter } = require('events');
const { FileManager } = require('./file-manager');
const { exec } = require('child_process');
const fs = require('fs');
const path = require('path');

class AgentRuntime extends EventEmitter {
  constructor(config) {
    super();
    this.config = config;
    this.fileManager = new FileManager(config.workspace);
    this.conversationHistory = [];
    this.systemPrompt = null;
    
    this.loadSystemPrompt();
    this.validateLLMBackend();
  }

  validateLLMBackend() {
    if (this.config.llm?.provider === 'claude-code') {
      // Check if claude CLI is available
      exec('claude --version', (error, stdout, stderr) => {
        if (error) {
          console.warn('[runtime] ⚠️  Claude CLI not found. Install with: pip install claude-cli');
        } else {
          console.log(`[runtime] ✅ Claude CLI available: ${stdout.trim()}`);
        }
      });
    } else if (this.config.llm?.provider === 'anthropic-api') {
      if (!this.config.llm?.apiKey) {
        console.warn('[runtime] ⚠️  Anthropic API provider selected but no API key configured');
      } else {
        console.log('[runtime] ✅ Anthropic API configured');
      }
    }
  }

  loadSystemPrompt() {
    try {
      if (this.config.agent.systemPrompt === 'auto') {
        // Load and concatenate context files
        const contextFiles = this.config.agent.contextFiles || [];
        this.systemPrompt = this.fileManager.loadContextFiles(contextFiles);
        if (!this.systemPrompt) {
          this.systemPrompt = this.getDefaultSystemPrompt();
        }
      } else {
        this.systemPrompt = this.config.agent.systemPrompt || this.getDefaultSystemPrompt();
      }
      console.log('[runtime] ✅ System prompt loaded');
    } catch (error) {
      console.warn('[runtime] ⚠️  Could not load system prompt, using default');
      this.systemPrompt = this.getDefaultSystemPrompt();
    }
  }

  getDefaultSystemPrompt() {
    return `You are ${this.config.agent.name || 'Jarvis'}, an AI assistant running locally on this machine via Claude Code CLI.

You have access to the local file system and can:
- Read and write files in the workspace
- Search through documents
- Keep memory notes
- Execute shell commands (when enabled)

Current workspace: ${this.config.workspace}

Be helpful, accurate, and respect the user's privacy. All data stays local.`;
  }

  // Process a chat message through the LLM
  async processMessage(message, options = {}) {
    if (!this.canUseLLM()) {
      throw new Error('LLM not configured. Please set up Claude CLI or Anthropic API key.');
    }

    try {
      // Add user message to history
      this.conversationHistory.push({
        role: 'user',
        content: message,
        timestamp: new Date().toISOString()
      });

      if (this.config.llm.provider === 'claude-code') {
        return await this.processWithClaudeCLI(message, options);
      } else if (this.config.llm.provider === 'anthropic-api') {
        return await this.processWithAnthropicAPI(message, options);
      } else {
        throw new Error(`Unsupported LLM provider: ${this.config.llm.provider}`);
      }

    } catch (error) {
      console.error('[runtime] Error processing message:', error);
      throw new Error(`Failed to process message: ${error.message}`);
    }
  }

  async processWithClaudeCLI(message, options = {}) {
    // Build the complete prompt with system context + conversation history + current message
    const fullPrompt = this.buildClaudePrompt(message);
    
    return new Promise((resolve, reject) => {
      let fullContent = '';
      let toolUses = [];
      let isToolMode = false;
      
      // Use echo + pipe approach for reliability
      const echoProcess = spawn('echo', [fullPrompt]);
      const claudeProcess = spawn(this.config.llm.claudePath || 'claude', ['--print'], {
        stdio: ['pipe', 'pipe', 'pipe']
      });
      
      // Pipe echo output to claude input
      echoProcess.stdout.pipe(claudeProcess.stdin);
      
      // Handle claude output
      claudeProcess.stdout.on('data', (data) => {
        const chunk = data.toString();
        
        // Check for tool usage patterns
        if (chunk.includes('<tool_use>') || isToolMode) {
          isToolMode = true;
          // Parse tool usage - simplified for now
          // In a real implementation, you'd parse XML-like tool usage
        }
        
        fullContent += chunk;
        
        if (options.stream && options.onChunk) {
          options.onChunk({ type: 'text', content: chunk });
        }
      });
      
      claudeProcess.stderr.on('data', (data) => {
        console.error('[runtime] Claude CLI error:', data.toString());
      });
      
      claudeProcess.on('close', async (code) => {
        if (code !== 0) {
          reject(new Error(`Claude CLI exited with code ${code}`));
          return;
        }
        
        try {
          // Parse the response for tool uses (basic implementation)
          const parsedResponse = this.parseClaudeResponse(fullContent);
          
          let finalContent = parsedResponse.content;
          let toolResults = [];
          
          // Execute tools if any were detected
          if (parsedResponse.toolUses.length > 0) {
            toolResults = await this.executeTools(parsedResponse.toolUses);
            
            if (options.onChunk) {
              options.onChunk({ type: 'tool_results', results: toolResults });
            }
            
            // Continue conversation with tool results if needed
            const followupResponse = await this.continueWithToolResults(parsedResponse.toolUses, toolResults, options);
            finalContent += followupResponse.content;
          }
          
          // Add assistant response to history
          this.conversationHistory.push({
            role: 'assistant',
            content: finalContent,
            timestamp: new Date().toISOString()
          });
          
          resolve({ content: finalContent, toolUses: parsedResponse.toolUses, toolResults });
          
        } catch (error) {
          reject(error);
        }
      });
      
      // Handle echo process completion
      echoProcess.on('close', (code) => {
        if (code !== 0) {
          reject(new Error(`Echo process failed with code ${code}`));
        }
      });
    });
  }

  buildClaudePrompt(newMessage) {
    let prompt = '';
    
    // Add system prompt
    if (this.systemPrompt) {
      prompt += `System: ${this.systemPrompt}\n\n`;
    }
    
    // Add conversation history
    for (const msg of this.conversationHistory.slice(-10)) { // Keep last 10 messages for context
      if (msg.role === 'user' || msg.role === 'assistant') {
        const role = msg.role === 'user' ? 'Human' : 'Assistant';
        prompt += `${role}: ${msg.content}\n\n`;
      }
    }
    
    // Add current message
    prompt += `Human: ${newMessage}\n\n`;
    
    // Add tool availability information
    if (this.config.features.fileAccess || this.config.features.shellAccess) {
      prompt += `Available tools:\n`;
      const tools = this.getAllTools();
      for (const tool of tools) {
        prompt += `- ${tool.name}: ${tool.description}\n`;
      }
      prompt += '\n';
    }
    
    prompt += 'Assistant: ';
    
    return prompt;
  }

  parseClaudeResponse(response) {
    // Basic parsing for tool usage - in a real implementation this would be more sophisticated
    // Claude CLI might output tool usage in a specific format
    const toolUses = [];
    let content = response;
    
    // Look for patterns like "I'll use the read_file tool" or function call syntax
    // This is a simplified implementation - actual parsing would be more robust
    const toolPatterns = [
      /read_file\(["']([^"']+)["']\)/g,
      /write_file\(["']([^"']+)["'],\s*["']([^"']+)["']\)/g,
      /list_files\(["']?([^"')]*)["']?\)/g,
      /search_files\(["']([^"']+)["']\)/g,
      /execute_shell\(["']([^"']+)["']\)/g
    ];
    
    // Simple tool extraction - would need more sophisticated parsing in production
    const readFileMatches = content.match(/read_file\(["']([^"']+)["']\)/g);
    if (readFileMatches) {
      for (const match of readFileMatches) {
        const pathMatch = match.match(/read_file\(["']([^"']+)["']\)/);
        if (pathMatch) {
          toolUses.push({
            id: `tool_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
            name: 'read_file',
            input: { file_path: pathMatch[1] }
          });
        }
      }
    }
    
    return { content, toolUses };
  }

  async processWithAnthropicAPI(message, options = {}) {
    // Fallback to Anthropic API - would need to import @anthropic-ai/sdk if this provider is used
    throw new Error('Anthropic API provider not implemented yet. Please use claude-code provider or implement anthropic-api support.');
  }

  async continueWithToolResults(toolUses, toolResults, options = {}) {
    // Build a follow-up prompt with tool results
    let followupPrompt = 'Tool results:\n';
    
    for (let i = 0; i < toolResults.length; i++) {
      const result = toolResults[i];
      const toolUse = toolUses[i];
      followupPrompt += `${toolUse.name}: ${result.result}\n`;
    }
    
    followupPrompt += '\nPlease provide your response based on these tool results.\n\nAssistant: ';
    
    // Use Claude CLI again for the follow-up
    return new Promise((resolve, reject) => {
      let followupContent = '';
      
      const echoProcess = spawn('echo', [followupPrompt]);
      const claudeProcess = spawn(this.config.llm.claudePath || 'claude', ['--print'], {
        stdio: ['pipe', 'pipe', 'pipe']
      });
      
      echoProcess.stdout.pipe(claudeProcess.stdin);
      
      claudeProcess.stdout.on('data', (data) => {
        const chunk = data.toString();
        followupContent += chunk;
        
        if (options.onChunk) {
          options.onChunk({ type: 'text', content: chunk });
        }
      });
      
      claudeProcess.on('close', (code) => {
        if (code !== 0) {
          resolve({ content: 'I encountered an error processing the tool results.' });
        } else {
          resolve({ content: followupContent });
        }
      });
      
      echoProcess.on('close', (code) => {
        if (code !== 0) {
          resolve({ content: 'I encountered an error processing the tool results.' });
        }
      });
    });
  }

  // Execute tool functions
  async executeTools(toolUses) {
    const results = [];

    for (const toolUse of toolUses) {
      try {
        console.log(`[runtime] Executing tool: ${toolUse.name}`);
        
        let result;
        const input = toolUse.input;
        
        if (this.isFileManagerTool(toolUse.name)) {
          result = await this.fileManager.executeTool(toolUse.name, input);
        } else if (toolUse.name === 'execute_shell' && this.config.features.shellAccess) {
          result = await this.executeShell(input.command);
        } else {
          result = `Unknown or disabled tool: ${toolUse.name}`;
        }

        results.push({
          tool_use_id: toolUse.id,
          result: result
        });

      } catch (error) {
        console.error(`[runtime] Tool execution error (${toolUse.name}):`, error);
        results.push({
          tool_use_id: toolUse.id,
          result: `Error: ${error.message}`
        });
      }
    }

    return results;
  }

  // Execute shell command (if enabled)
  async executeShell(command) {
    return new Promise((resolve, reject) => {
      const timeout = 30000; // 30 second timeout
      
      exec(command, { 
        cwd: this.config.workspace,
        timeout: timeout,
        maxBuffer: 1024 * 1024 // 1MB max output
      }, (error, stdout, stderr) => {
        if (error) {
          resolve(`Command failed: ${error.message}\nStderr: ${stderr}`);
        } else {
          resolve(stdout || stderr || 'Command completed successfully');
        }
      });
    });
  }

  // Get all available tools
  getAllTools() {
    const tools = this.fileManager.getTools();
    
    if (this.config.features.shellAccess) {
      tools.push({
        name: 'execute_shell',
        description: 'Execute a shell command in the workspace directory',
        parameters: {
          type: 'object',
          properties: {
            command: {
              type: 'string',
              description: 'Shell command to execute'
            }
          },
          required: ['command']
        }
      });
    }

    return tools;
  }

  isFileManagerTool(toolName) {
    return ['read_file', 'write_file', 'list_files', 'search_files', 'append_memory'].includes(toolName);
  }

  canUseLLM() {
    if (this.config.llm?.provider === 'claude-code') {
      return true; // Assume claude CLI is available
    }
    return !!(this.config.llm?.apiKey);
  }

  // Clear conversation history
  clearHistory() {
    this.conversationHistory = [];
  }

  // Get conversation history
  getHistory() {
    return [...this.conversationHistory];
  }

  // Save conversation to file
  saveConversation(filePath) {
    try {
      const data = {
        timestamp: new Date().toISOString(),
        config: {
          provider: this.config.llm?.provider,
          model: this.config.llm?.model,
          agent: this.config.agent.name
        },
        history: this.conversationHistory
      };
      
      fs.writeFileSync(filePath, JSON.stringify(data, null, 2), 'utf8');
      return 'Conversation saved successfully';
    } catch (error) {
      throw new Error(`Failed to save conversation: ${error.message}`);
    }
  }

  // Load conversation from file
  loadConversation(filePath) {
    try {
      const data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
      this.conversationHistory = data.history || [];
      return `Conversation loaded: ${data.history?.length || 0} messages`;
    } catch (error) {
      throw new Error(`Failed to load conversation: ${error.message}`);
    }
  }

  // Update configuration
  updateConfig(newConfig) {
    this.config = { ...this.config, ...newConfig };
    
    // Reload system prompt if agent config changed
    if (newConfig.agent) {
      this.loadSystemPrompt();
    }
    
    // Update file manager workspace if changed
    if (newConfig.workspace) {
      this.fileManager = new FileManager(newConfig.workspace);
    }
    
    // Validate new LLM backend
    if (newConfig.llm) {
      this.validateLLMBackend();
    }
  }

  // Get runtime status
  getStatus() {
    return {
      llmConfigured: this.canUseLLM(),
      llmProvider: this.config.llm?.provider,
      systemPromptLoaded: !!this.systemPrompt,
      conversationLength: this.conversationHistory.length,
      workspace: this.config.workspace,
      model: this.config.llm?.model,
      agentName: this.config.agent?.name
    };
  }
}

module.exports = { AgentRuntime };