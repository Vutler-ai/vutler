<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vutler — Your AI Workforce</title>
  <meta name="description" content="Deploy autonomous AI agents that work 24/7. Build from templates or bring your existing infrastructure. No per-seat pricing. Full API control.">
  <link rel="stylesheet" href="styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Navigation -->
  <nav class="navbar" id="navbar">
    <div class="container nav-container">
      <a href="#" class="logo"><img src="vutler-logo-full-white.png" alt="Vutler" height="36" style="object-fit:contain">
      </a>
      <div class="nav-links" id="nav-links">
        <a href="#features">Features</a>
        <a href="/landing/pricing.html">Pricing</a>
        <a href="/landing/docs.html">Docs</a>
        <a href="/demo" style="color:#3b82f6;font-weight:600">🎬 Live Demo</a>
        <a href="/landing/about.html">About</a>
      </div>
      <div class="nav-actions">
        <a href="/landing/login.html" class="btn btn-ghost">Sign In</a>
        <a href="/landing/signup.html" class="btn btn-primary">Get Started</a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="badge-pulse"></span>
            <span>Now with GPT-4o &amp; Claude Sonnet integration</span>
          </div>
          <h1 class="hero-title">
            Build your<br>
            <span class="gradient-text">AI workforce</span><br>
            or bring your own
          </h1>
          <p class="hero-subtitle">
            Deploy autonomous AI agents in minutes. Handle emails, chats, files, and tasks 24/7.
            No per-seat pricing. Full API control.
          </p>
          <div class="hero-cta">
            <a href="/demo" class="btn btn-ghost btn-lg" style="border:2px solid #3b82f6;color:#3b82f6;margin-right:12px">🎬 Live Demo</a>
            <a href="/landing/signup.html" class="btn btn-primary btn-lg">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              Get Started Free
            </a>
            <a href="#contact" class="btn btn-outline btn-lg">Request Demo →</a>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <strong><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1L10 6L15 6.5L11.5 10L12.5 15L8 12.5L3.5 15L4.5 10L1 6.5L6 6Z"/></svg> Open Beta</strong>
              <span>Free to try</span>
            </div>
            <div class="stat-sep"></div>
            <div class="stat">
              <strong><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 7V4.5a3.5 3.5 0 0 1 7 0M3 7h10v7.5H3z"/></svg> Open Source</strong>
              <span>AGPL-3.0</span>
            </div>
            <div class="stat-sep"></div>
            <div class="stat">
              <strong><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="14" height="14" rx="2"/><path d="M8 4v8M4 8h8"/></svg> Swiss Hosted</strong>
              <span>Geneva, Switzerland</span>
            </div>
            <div class="stat-sep"></div>
            <div class="stat">
              <strong><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 1L3 9h4.5L7 15L13 7H8.5z"/></svg> 100+ Features</strong>
              <span>Agents, API & more</span>
            </div>
          </div>
        </div>

        <!-- Dashboard Mockup -->
        <div class="hero-visual">
          <div class="dashboard-mockup">
            <div class="mockup-header">
              <div class="mockup-dots">
                <span class="dot dot-red"></span>
                <span class="dot dot-yellow"></span>
                <span class="dot dot-green"></span>
              </div>
              <span class="mockup-title">Vutler Dashboard</span>
            </div>
            <div class="mockup-body">
              <!-- Stats row -->
              <div class="mockup-stats">
                <div class="mockup-stat-card">
                  <span class="mstat-label">Active Agents</span>
                  <span class="mstat-value">12</span>
                  <span class="mstat-trend trend-up">▲ +3 this week</span>
                </div>
                <div class="mockup-stat-card">
                  <span class="mstat-label">Tasks Today</span>
                  <span class="mstat-value">847</span>
                  <span class="mstat-trend trend-up">▲ +12%</span>
                </div>
                <div class="mockup-stat-card">
                  <span class="mstat-label">Token Usage</span>
                  <span class="mstat-value">2.4M</span>
                  <span class="mstat-trend trend-neutral">of 5M limit</span>
                </div>
              </div>
              <!-- Agent list -->
              <div class="mockup-agents">
                <div class="mockup-agent-row">
                  <div class="agent-dot online"></div>
                  <span class="agent-row-name">Support Agent</span>
                  <span class="agent-row-tasks">124 tasks</span>
                  <span class="agent-row-badge online-badge">Online</span>
                </div>
                <div class="mockup-agent-row">
                  <div class="agent-dot online"></div>
                  <span class="agent-row-name">Sales Bot</span>
                  <span class="agent-row-tasks">89 tasks</span>
                  <span class="agent-row-badge online-badge">Online</span>
                </div>
                <div class="mockup-agent-row">
                  <div class="agent-dot busy"></div>
                  <span class="agent-row-name">Data Analyst</span>
                  <span class="agent-row-tasks">Processing…</span>
                  <span class="agent-row-badge busy-badge">Busy</span>
                </div>
                <div class="mockup-agent-row">
                  <div class="agent-dot offline"></div>
                  <span class="agent-row-name">Email Handler</span>
                  <span class="agent-row-tasks">Idle</span>
                  <span class="agent-row-badge offline-badge">Idle</span>
                </div>
              </div>
              <!-- Live feed -->
              <div class="mockup-feed">
                <div class="feed-item">
                  <span class="feed-icon feed-email"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="14" height="10" rx="1.5"/><path d="M1 4.5L8 9L15 4.5"/></svg></span>
                  <span class="feed-text"><strong>Support Agent</strong> replied to 3 tickets</span>
                  <span class="feed-time">now</span>
                </div>
                <div class="feed-item">
                  <span class="feed-icon feed-chat"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 2h12v9H5L2 14z"/></svg></span>
                  <span class="feed-text"><strong>Sales Bot</strong> closed a lead on Slack</span>
                  <span class="feed-time">1m</span>
                </div>
                <div class="feed-item">
                  <span class="feed-icon feed-file"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 3h4.5l2 2h6.5v8.5h-13z"/></svg></span>
                  <span class="feed-text"><strong>Data Analyst</strong> exported report.csv</span>
                  <span class="feed-time">4m</span>
                </div>
              </div>
            </div>
          </div>
          <!-- Floating badges -->
          <div class="float-badge float-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#22c55e"><circle cx="12" cy="12" r="10"/></svg>
            <span>GPT-4o connected</span>
          </div>
          <div class="float-badge float-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#3b82f6"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <span>847 tasks done today</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos strip -->
  <section class="logos-strip">
    <div class="container">
      <p class="logos-label">Integrates with your stack</p>
      <div class="logos-row">
        <div class="logo-chip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/></svg>
          OpenAI
        </div>
        <div class="logo-chip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.3 3.9c-1.5-.9-3.2-1.4-5-1.4-2.8 0-5.3 1.1-7.1 2.9C3.4 7.2 2.3 9.7 2.3 12.5c0 3.8 2 7.1 5 9l1.3-2.2c-2.3-1.4-3.8-3.9-3.8-6.8 0-4.3 3.5-7.8 7.8-7.8 1.4 0 2.7.4 3.8 1l1.9-1.8zm-10.6 16.2c1.5.9 3.2 1.4 5 1.4 2.8 0 5.3-1.1 7.1-2.9 1.8-1.8 2.9-4.3 2.9-7.1 0-3.8-2-7.1-5-9l-1.3 2.2c2.3 1.4 3.8 3.9 3.8 6.8 0 4.3-3.5 7.8-7.8 7.8-1.4 0-2.7-.4-3.8-1L6.7 20.1z"/></svg>
          Anthropic
        </div>
        <div class="logo-chip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M5.8 3h12.4C19.2 3 20 3.8 20 4.8v14.4c0 1-.8 1.8-1.8 1.8H5.8C4.8 21 4 20.2 4 19.2V4.8C4 3.8 4.8 3 5.8 3zm0 1.5c-.2 0-.3.1-.3.3v14.4c0 .2.1.3.3.3h12.4c.2 0 .3-.1.3-.3V4.8c0-.2-.1-.3-.3-.3H5.8zM8 8h8v1.5H8V8zm0 3.5h8V13H8v-1.5zm0 3.5h5V16.5H8V15z"/></svg>
          Slack
        </div>
        <div class="logo-chip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.112 18.1.13 18.116a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
