# Vutler API Configuration
# Copy this file to .env.local and configure for your environment

# Backend API URL (Express API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production example:
# NEXT_PUBLIC_API_URL=https://api.vutler.ai

# Push Notifications (VAPID public key — must match backend VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
